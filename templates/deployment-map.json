{
    "include": {
        "templates/homepage/index.html": "index.html",
        "templates/<page>.html": "<page>/index.html",
        
        "content/notes/<cat>/<typ>/<title>.<ext>": "notes/<cat>/<typ>/<title>.<ext>",
        "content/notes/<cat>/<typ>/<title>.md": "notes/<cat>/<typ>/<title>.md/index.html",
        "content/notes/<cat>/<typ>/<title>/<file>": "notes/<cat>/<typ>/<title>/<file>",
        "content/notes/<cat>/<typ>/<title>/index.md": "notes/<cat>/<typ>/<title>/index.html",

        "templates/blog/blog.html": "blog/index.html",
        "content/blog/<slug>.md": "blog/<slug>.md/index.html",
        "content/blog/<slug>/<file>": "blog/<slug>/<file>",
        "content/blog/<slug>/index.md": "blog/<slug>/index.html",

        "templates/projects/projects-homepage.html": "projects/index.html",
        "content/projects/*/<folder>/<folder>.md": "projects/<folder>/index.html",
        "content/projects/*/<folder>/<folder>.html": "projects/<folder>/index.html",
        "content/projects/*/<folder>/<file>": "projects/<folder>/<file>"
    },
    "exclude": {
        "content/projects/*/<folder>/<folder>.md": "projects/<folder>/<folder>.md",
        "content/projects/*/<folder>/<folder>.html": "projects/<folder>/<folder>.html",
        "content/projects/*/<folder>/<folder>.json": "projects/<folder>/<folder>.json",
        "content/notes/<cat>/<typ>/<title>/index.md": "notes/<cat>/<typ>/<title>/index.md",
        "content/blog/<slug>/index.md": "blog/<slug>/index.md"
    }
}